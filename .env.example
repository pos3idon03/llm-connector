# HuggingFace model ID — local path also accepted (e.g. /data/models/llama3)
MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct

# Fraction of GPU VRAM reserved for the KV cache (0.0–1.0)
GPU_MEMORY_UTILIZATION=0.90

# Number of GPUs for tensor parallelism — 1 for single-GPU setups
TENSOR_PARALLEL_SIZE=1

# Max sequence length override — leave blank to use the model's default
MAX_MODEL_LEN=

# Weight dtype: auto, float16, bfloat16, float32
DTYPE=auto

# Quantization method: awq, gptq, squeezellm — leave blank for none
QUANTIZATION=

# Set to true only for models that explicitly require it (security risk)
TRUST_REMOTE_CODE=false

# Server bind address and port
HOST=0.0.0.0
PORT=8000

# HuggingFace credentials (required for gated models like Llama, Mistral)
# HF_TOKEN=hf_...

# Override HuggingFace cache directory (useful for shared model storage)
# HF_HOME=/data/hf_cache
